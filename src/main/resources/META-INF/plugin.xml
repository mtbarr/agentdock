<idea-plugin>
    <id>unified.llm.plugin</id>
    <name>Unified LLM Plugin</name>
    <vendor>E</vendor>

    <description><![CDATA[
    Unified LLM Plugin - A high-performance AI coding assistant for JetBrains IDEs.
    ]]></description>

     <depends>com.intellij.modules.platform</depends>
     <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="unified.llm.acp.AcpStartupActivity"/>
         <toolWindow id="UnifiedLLM" icon="/icons/unified_toolwindow.svg" anchor="right"
                     factoryClass="unified.llm.UnifiedLlmToolWindowFactory"/>
     </extensions>

    <actions>
        <action id="UnifiedLLM.AddCodeReferenceToChatAction"
                class="unified.llm.AddCodeReferenceToChatAction"
                text="Add to Chat"
                description="Add the selected code range to the chat input"
                icon="/icons/unified_toolwindow.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
        <action id="UnifiedLLM.AddFileReferenceToChatAction"
                class="unified.llm.AddFileReferenceToChatAction"
                text="Add to Chat"
                description="Add the selected file reference to the chat"
                icon="/icons/unified_toolwindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </action>
        <action id="UnifiedLLM.GenerateGitCommitMessageAction"
                class="unified.llm.gitcommit.GenerateGitCommitMessageAction"
                text="Generate Commit Message"
                description="Generate a commit message with the configured AI agent"
                icon="/icons/unified_toolwindow.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
