<idea-plugin>
    <id>agentdock</id>
    <name>AgentDock</name>
    <vendor>E</vendor>

    <description><![CDATA[
    Provides widely used AI coding agents such as Codex, Claude Code, Copilot, and others with a rich GUI that follows your JetBrains IDE theme.
    ]]></description>

     <depends>com.intellij.modules.platform</depends>
     <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="agentdock.acp.AcpStartupActivity"/>
         <toolWindow id="AgentDock" icon="/icons/agent_dock_toolwindow.svg" anchor="right"
                     factoryClass="agentdock.AgentDockToolWindowFactory"/>
     </extensions>

    <actions>
        <action id="AgentDock.AddCodeReferenceToChatAction"
                class="agentdock.AddCodeReferenceToChatAction"
                text="Add to Chat"
                description="Add the selected code range to the chat input"
                icon="/icons/agent_dock_toolwindow.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
        <action id="AgentDock.AddFileReferenceToChatAction"
                class="agentdock.AddFileReferenceToChatAction"
                text="Add to Chat"
                description="Add the selected file reference to the chat"
                icon="/icons/agent_dock_toolwindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </action>
        <action id="AgentDock.GenerateGitCommitMessageAction"
                class="agentdock.gitcommit.GenerateGitCommitMessageAction"
                text="Generate Commit Message"
                description="Generate a commit message with the configured AI agent"
                icon="/icons/agent_dock_toolwindow.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
