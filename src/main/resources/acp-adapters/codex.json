{
  "id": "codex",
  "name": "Codex",
  "iconPath": "/icons/codex.svg",
  "iconPathLight": "/icons/codex-light.svg",
  "iconPathDark": "/icons/codex-dark.svg",
  "distribution": {
    "type": "archive",
    "version": "latest",
    "downloadUrl": "https://github.com/zed-industries/codex-acp/releases/download/v{version}/codex-acp-{version}-{target}.{ext}",
    "updateSource": {
      "type": "github_release",
      "owner": "zed-industries",
      "repo": "codex-acp",
      "tagPrefix": "v"
    },
    "binaryName": {
      "win": "codex-acp.exe",
      "unix": "codex-acp"
    }
  },
  "disabledModels": [
    "-5.3",
    "-5.1",
    "-5.2"
  ],
  "disabledModes": [],
  "agentVersionConfig": {
    "args": ["--version"],
    "pattern": "(\\d+\\.\\d+[\\d.\\-]*)"
  },
  "authConfig": {
    "uiMode": "login_logout",
    "loginMode": "background",
    "authNpmPackage": "@openai/codex",
    "statusArgs": [
      "login",
      "status"
    ],
    "loginArgs": [
      "login"
    ],
    "logoutArgs": [
      "logout"
    ]
  },
  "cli": {
    "executable": {
      "win": "node_modules\\.bin\\codex.cmd",
      "unix": "node_modules/.bin/codex"
    },
    "resumeArgs": [
      "resume",
      "{sessionId}"
    ]
  }
}
