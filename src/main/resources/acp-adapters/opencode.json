{
  "id": "opencode",
  "name": "OpenCode",
  "iconPath": "/icons/opencode.svg",
  "iconPathLight": "/icons/opencode-light.svg",
  "iconPathDark": "/icons/opencode-dark.svg",
  "distribution": {
    "type": "npm",
    "version": "latest",
    "packageName": "opencode-ai"
  },
  "launchBinary": {
    "win": "node_modules/.bin/opencode.cmd",
    "unix": "node_modules/opencode-ai/bin/opencode"
  },
  "args": [
    "acp"
  ],
  "cli": {
    "executable": {
      "win": "node_modules/.bin/opencode.cmd",
      "unix": "node_modules/opencode-ai/bin/opencode"
    },
    "resumeArgs": [
      "--session",
      "{sessionId}"
    ]
  },
  "authConfig": {
    "uiMode": "manage_terminal",
    "loginMode": "manage_terminal"
  },
  "disabledModels": [
    "gpt-5.1",
    "gpt-5.2"
  ]
}
