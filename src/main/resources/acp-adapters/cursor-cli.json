{
  "id": "cursor-cli",
  "name": "Cursor",
  "iconPath": "/icons/cursor.svg",
  "iconPathLight": "/icons/cursor-light.svg",
  "iconPathDark": "/icons/cursor-dark.svg",
  "supportsSessionList": false,
  "distribution": {
    "type": "archive",
    "version": "2026.04.16-2d20146",
    "downloadUrl": "https://downloads.cursor.com/lab/{version}/{platform}/{arch}/agent-cli-package.{ext}",
    "extractSubdir": "dist-package",
    "binaryName": {
      "win": "cursor-agent.cmd",
      "unix": "cursor-agent"
    }
  },
  "args": [
    "acp"
  ],
  "cli": {
    "executable": {
      "win": "cursor-agent.cmd",
      "unix": "./cursor-agent"
    },
    "resumeArgs": [
      "--resume",
      "{sessionId}"
    ]
  },
  "authConfig": {
    "uiMode": "login_logout",
    "loginMode": "background",
    "statusArgs": [
      "about"
    ],
    "loginArgs": [
      "login"
    ],
    "logoutArgs": [
      "logout"
    ]
  },
  "disabledModels": [
    "composer-1",
    "gemini-2",
    "gpt-5.1",
    "gpt-5.2",
    "claude-opus-4-5",
    "claude-sonnet-4-5"
  ],
  "disabledModes": []
}
