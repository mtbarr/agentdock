{
  "id": "gemini-cli",
  "name": "Gemini",
  "iconPath": "/icons/gemini.svg",
  "supportsSessionList": false,
  "distribution": {
    "type": "npm",
    "packageName": "@google/gemini-cli",
    "version": "latest"
  },
  "launchBinary": {
    "win": "node_modules/.bin/gemini.cmd",
    "unix": "node_modules/.bin/gemini"
  },
  "args": [
    "--acp"
  ],
  "defaultModel": {
    "modelId": "gemini-3-flash-preview",
    "name": "Gemini 3 Flash",
    "description": ""
  },
  "disabledModels": [
    "-2.",
    "3.1-flash-lite",
    "auto"
  ],
  "defaultMode": {
    "modeId": "default",
    "name": "Default",
    "description": "Prompts for approval"
  },
  "disabledModes": [],
  "patches": [
    "@patches/gemini/usage-config.patch",
    "@patches/gemini/usage-gemini.patch",
    "@patches/gemini/usage-run.patch"
  ],
  "cli": {
    "executable": {
      "win": "node_modules/.bin/gemini.cmd",
      "unix": "node_modules/.bin/gemini"
    },
    "resumeArgs": [
      "--resume",
      "{sessionId}"
    ]
  },
  "authConfig": {
    "uiMode": "manage_terminal",
    "loginMode": "manage_terminal"
  }
}
