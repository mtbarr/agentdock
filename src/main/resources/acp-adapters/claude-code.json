{
  "id": "claude-code",
  "name": "Claude Code",
  "iconPath": "/icons/claude.svg",
  "distribution": {
    "type": "npm",
    "version": "latest",
    "packageName": "@agentclientprotocol/claude-agent-acp"
  },
  "disabledModels": [],
  "disabledModes": [],
  "patches": [],
  "cli": {
    "executable": {
      "win": "node.exe",
      "unix": "node"
    },
    "entryPath": "node_modules/@agentclientprotocol/claude-agent-acp/dist/index.js",
    "args": [
      "--cli"
    ],
    "resumeArgs": [
      "-r",
      "{sessionId}"
    ]
  },
  "modelChangeStrategy": "restart-resume",
  "agentVersionConfig": {
    "args": ["--cli", "--version"],
    "pattern": "(\\d+\\.\\d+[\\d.\\-]*)"
  },
  "authConfig": {
    "uiMode": "login_logout",
    "loginMode": "background",
    "statusArgs": [
      "--cli",
      "auth",
      "status"
    ],
    "loginArgs": [
      "--cli",
      "auth",
      "login"
    ],
    "logoutArgs": [
      "--cli",
      "auth",
      "logout"
    ]
  }
}
